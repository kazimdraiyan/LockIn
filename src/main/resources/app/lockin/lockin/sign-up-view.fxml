<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720" prefWidth="1280" style="-fx-background-color: linear-gradient(to bottom right,#0F4C75,#1B9AAA);" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.lockin.lockin.client.controller.SignUpController">

    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- LEFT BRANDING AREA -->
        <VBox alignment="CENTER" prefWidth="480" spacing="20" style="-fx-background-color: linear-gradient(to bottom right,#0F4C75,#1B9AAA);">

            <padding>
                <Insets bottom="40" left="50" right="50" top="40" />
            </padding>

            <Button text="⌂  Home"
                    onAction="#onHomeButtonClick"
                    style="
                        -fx-background-color: rgba(255,255,255,0.15);
                        -fx-background-radius: 8;
                        -fx-border-color: rgba(255,255,255,0.35);
                        -fx-border-radius: 8;
                        -fx-border-width: 1.5;
                        -fx-text-fill: white;
                        -fx-font-size: 13;
                        -fx-cursor: hand;
                        -fx-padding: 7 16 7 16;
                    "/>

            <!-- LOGO PLACEHOLDER -->
            <StackPane prefHeight="120" prefWidth="120" style="
                -fx-background-color: rgba(255,255,255,0.15);
                -fx-background-radius: 20;
                -fx-border-radius: 20;
                -fx-border-color: rgba(255,255,255,0.25);
                -fx-border-width: 2;
            ">
                <Label style="-fx-text-fill:white; -fx-opacity:0.7;" text="LOGO" />
            </StackPane>

            <!-- APP NAME -->
            <Label text="LockIn" textFill="WHITE">
                <font>
                    <Font size="34" />
                </font>
            </Label>

            <!-- TAGLINE -->
            <Label alignment="CENTER" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size:15;" text="Secure your workflow. Start today." wrapText="true" />
        </VBox>

        <!-- RIGHT SIGNUP CARD -->
        <StackPane style="-fx-background-color:#f6f8fa;" HBox.hgrow="ALWAYS">

            <VBox prefWidth="700" maxHeight="-Infinity" maxWidth="700" spacing="14" style="
                -fx-background-color:white;
                -fx-background-radius:14;
                -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.18), 25,0.2,0,6);
            ">

                <padding>
                    <Insets bottom="40" left="40" right="40" top="40" />
                </padding>

                <Label text="Sign Up">
                    <font>
                        <Font size="26" />
                    </font>
                </Label>

                <Label style="-fx-text-fill:#777777;" text="Create your account to get started" />

                <!-- Username -->
                <VBox spacing="5">
                    <Label style="-fx-text-fill:#555555;" text="Username" />
                    <TextField fx:id="nameField" prefHeight="40" promptText="Enter your username" style="-fx-background-color:#f4f6f8; -fx-background-radius:8; -fx-padding:10;" />
                </VBox>

                <!-- Password -->
                <VBox spacing="5">
                    <Label style="-fx-text-fill:#555555;" text="Password" />
                    <PasswordField fx:id="passwordField" prefHeight="40" promptText="Enter password" style="-fx-background-color:#f4f6f8; -fx-background-radius:8; -fx-padding:10;" />
                </VBox>

                <!-- Confirm Password -->
                <VBox spacing="5">
                    <Label style="-fx-text-fill:#555555;" text="Confirm Password" />
                    <PasswordField fx:id="confirmPasswordField" prefHeight="40" promptText="Confirm password" style="-fx-background-color:#f4f6f8; -fx-background-radius:8; -fx-padding:10;" />
                </VBox>

                <!-- Sign Up Button -->
                <Button fx:id="signUpButton" maxWidth="Infinity" prefHeight="42" style="
                    -fx-background-color: linear-gradient(to right,#1B9AAA,#00C9A7);
                    -fx-background-radius:10;
                    -fx-text-fill:white;
                    -fx-font-weight:bold;
                    -fx-cursor:hand;
                " text="Sign Up" onAction="#signUp"
                />

                <!-- Footer -->
                <HBox alignment="CENTER" spacing="6">
                    <Label style="-fx-text-fill:#777777;" text="Already have an account?" />
                    <Hyperlink onAction="#onSignInLinkClick" style="-fx-text-fill:#1B9AAA; -fx-font-weight:bold;" text="Sign In" />
                </HBox>

            </VBox>
        </StackPane>

    </HBox>
</AnchorPane>
