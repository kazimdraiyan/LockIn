<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.BorderPane?>

<?import javafx.scene.control.Button?>
<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="app.lockin.lockin.client.controller.MainController">
    <center>
        <VBox alignment="CENTER" spacing="20.0">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
            </padding>

            <Label fx:id="welcomeText" text="Welcome to LockIn"/>
            <Button text="Login" onAction="#onLoginButtonClick"/>
            <Button text="Sign Up" onAction="#onSignUpButtonClick"/>
        </VBox>
    </center>
</BorderPane>
