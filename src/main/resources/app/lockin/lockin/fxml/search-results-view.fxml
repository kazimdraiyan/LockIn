<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" styleClass="panel-muted" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.lockin.lockin.client.controllers.SearchResultsController">
    <padding>
        <Insets bottom="16" left="16" right="16" top="16"/>
    </padding>

    <VBox spacing="6">
        <Label styleClass="section-title" text="User search"/>
        <Label fx:id="queryLabel" styleClass="muted-text" text="Results"/>
        <Label fx:id="statusLabel" styleClass="muted-text"/>
    </VBox>

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
        <VBox fx:id="resultsContainer" spacing="12">
            <padding>
                <Insets bottom="18" top="4"/>
            </padding>
        </VBox>
    </ScrollPane>
</VBox>
