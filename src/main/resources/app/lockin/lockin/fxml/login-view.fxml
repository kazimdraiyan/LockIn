<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="720" prefWidth="1280" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.lockin.lockin.client.controllers.LoginController">

    <!-- MAIN TWO COLUMN LAYOUT -->
    <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

        <!-- ================= LEFT SIDE (BRANDING) ================= -->
        <VBox alignment="CENTER" prefWidth="480" spacing="20" styleClass="left-panel">

            <padding>
                <Insets bottom="40" left="50" right="50" top="40" />
            </padding>

            <!-- APP NAME -->
            <Label styleClass="inverse-text" text="LockIn">
                <font>
                    <Font size="34" />
                </font>
            </Label>

            <!-- TAGLINE -->
            <Label alignment="CENTER" styleClass="tagline-text" text="Focus. Secure. Achieve." wrapText="true" />
        </VBox>


        <!-- ================= RIGHT SIDE (LOGIN UI) ================= -->
        <StackPane styleClass="right-panel" HBox.hgrow="ALWAYS">

            <!-- LOGIN CARD -->
            <VBox maxHeight="-Infinity" maxWidth="700" prefWidth="700" spacing="14" styleClass="card">

                <padding>
                    <Insets bottom="40" left="40" right="40" top="40" />
                </padding>

                <Label styleClass="section-title" text="Login">
                    <font>
                        <Font size="26" />
                    </font>
                </Label>

                <Label styleClass="card-subtitle" text="Welcome back! Please login to continue." />

                <!-- Username -->
                <VBox spacing="5">
                    <Label styleClass="card-label" text="Username" />
                    <TextField fx:id="usernameField" prefHeight="40" promptText="Enter your ID" styleClass="input-field" />
                </VBox>

                <!-- Password -->
                <VBox spacing="5">
                    <Label styleClass="card-label" text="Password" />
                    <PasswordField fx:id="passwordField" prefHeight="40" promptText="Enter password" styleClass="input-field" />
                </VBox>

            <Label fx:id="errorLabel" prefHeight="17.0" prefWidth="629.0" styleClass="error-label" text="Label" visible="false" wrapText="true" />

                <Button fx:id="signInButton" maxWidth="Infinity" onAction="#login" prefHeight="42" styleClass="primary-button" text="Login" />

                <HBox alignment="CENTER" spacing="6">
                    <Label styleClass="card-subtitle" text="Don't have an account?" />
                    <Hyperlink onAction="#onSignUpLinkClick" styleClass="link-button" text="Sign Up" />
                </HBox>

            </VBox>
        </StackPane>

    </HBox>
</AnchorPane>
