<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="TOP_CENTER" spacing="12" styleClass="panel-muted" xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.lockin.lockin.client.controllers.SettingsController">
    <padding>
        <Insets bottom="12" left="16" right="16" top="12"/>
    </padding>

    <VBox maxWidth="760" spacing="12" styleClass="feed-card">
        <padding>
            <Insets bottom="12" left="16" right="16" top="12"/>
        </padding>

        <Label styleClass="section-title" text="Change Password"/>

        <VBox spacing="8">
            <Label styleClass="label-text" text="Current password"/>
            <PasswordField fx:id="oldPasswordField" promptText="Enter your current password" styleClass="input-field"
                           prefWidth="220" maxWidth="220"/>
        </VBox>

        <VBox spacing="8">
            <Label styleClass="label-text" text="New password"/>
            <PasswordField fx:id="newPasswordField" promptText="Enter your new password" styleClass="input-field"
                           prefWidth="220" maxWidth="220"/>
        </VBox>

        <VBox spacing="8">
            <Label styleClass="label-text" text="Confirm new password"/>
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm your new password" styleClass="input-field"
                           prefWidth="220" maxWidth="220"/>
        </VBox>

        <HBox alignment="CENTER_LEFT" spacing="10">
            <Button fx:id="changePasswordButton" onAction="#onChangePasswordClick" styleClass="primary-button"
                    text="Change password"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>

        <Label fx:id="statusLabel" styleClass="muted-text" text=""/>
    </VBox>

    <VBox maxWidth="760" spacing="12" styleClass="feed-card">
        <padding>
            <Insets bottom="12" left="16" right="16" top="12"/>
        </padding>

        <Label styleClass="section-title" text="Account"/>

        <Button fx:id="logoutButton" onAction="#onLogoutClick" styleClass="danger-button" text="Logout"/>
    </VBox>
</VBox>
