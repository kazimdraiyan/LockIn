<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="app.lockin.lockin.client.controllers.WelcomeController"
            prefHeight="720" prefWidth="1280">
        <HBox AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">

            <!-- ================= LEFT SIDE (BRANDING) ================= -->
            <VBox alignment="CENTER" prefWidth="480" spacing="20" styleClass="auth-brand-panel">
                <padding>
                    <Insets bottom="40" left="50" right="50" top="40" />
                </padding>

                <!-- APP NAME -->
                <Label styleClass="auth-brand-title" text="LockIn">
                    <font>
                        <Font size="34" />
                    </font>
                </Label>

                <!-- TAGLINE -->
                <Label alignment="CENTER" styleClass="auth-brand-subtitle" text="Focus. Secure. Achieve." wrapText="true" />
            </VBox>

            <!-- ================= RIGHT SIDE (HOME CARD) ================= -->
            <StackPane alignment="CENTER" styleClass="right-panel" HBox.hgrow="ALWAYS">

                <VBox maxHeight="-Infinity" maxWidth="700" prefWidth="700" spacing="16" styleClass="card">
                    <padding>
                        <Insets bottom="40" left="40" right="40" top="40" />
                    </padding>

                    <!-- HEADING -->
                    <Label styleClass="section-title" text="Welcome Back">
                        <font>
                            <Font size="26" />
                        </font>
                    </Label>

                    <Label styleClass="card-subtitle" text="Login to your account or create a new one to get started." wrapText="true" />

                    <!-- DIVIDER -->
                    <StackPane maxWidth="Infinity" prefHeight="1" styleClass="divider" />

                    <!-- LOGIN BUTTON -->
                    <VBox spacing="6">
                        <Label styleClass="card-label" text="Already have an account?" />
                        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#onLoginButtonClick" prefHeight="42" styleClass="primary-button" text="Login" />
                    </VBox>

                    <!-- SIGN UP BUTTON -->
                    <VBox spacing="6">
                        <Label styleClass="card-label" text="New to LockIn?" />
                        <Button fx:id="signUpButton" maxWidth="Infinity" onAction="#onSignUpButtonClick" prefHeight="42" styleClass="primary-button" text="Create Account" />
                    </VBox>

                </VBox>
            </StackPane>

        </HBox>
</AnchorPane>
