<?xml version="1.0" encoding="UTF-8"?>

<?import app.lockin.lockin.client.elements.ProfileAvatar?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1280" styleClass="screen-root" xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.lockin.lockin.client.controllers.HomeController">
    <center>
        <HBox spacing="0" styleClass="panel-muted">
            <VBox prefWidth="260" spacing="2">
                <padding>
                    <Insets bottom="12" left="12" right="8" top="12"/>
                </padding>

                <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="12" styleClass="nav-item nav-item-active">
                    <ImageView preserveRatio="true">
                        <Image url="@../icon/home.png"/>
                    </ImageView>
                    <Label styleClass="text-strong" text="Home"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="12" onMouseClicked="#onChatsButtonClick" styleClass="nav-item">
                    <ImageView preserveRatio="true">
                        <Image url="@../icon/chat.png"/>
                    </ImageView>
                    <Label styleClass="text-strong" text="Chats"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="12" styleClass="nav-item" onMouseClicked="#onProfileButtonClick">
                    <ProfileAvatar fx:id="profileNavAvatar" size="32.0" text="Me"/>
                    <Label fx:id="profileNavLabel" styleClass="text-strong" text="Profile"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" prefHeight="48" spacing="12" styleClass="nav-item">
                    <ImageView preserveRatio="true">
                        <Image url="@../icon/bookmark.png"/>
                    </ImageView>
                    <Label styleClass="text-strong" text="Saved"/>
                </HBox>
            </VBox>

            <VBox spacing="12" HBox.hgrow="ALWAYS">
                <padding>
                    <Insets bottom="12" left="8" right="8" top="12"/>
                </padding>

                <VBox spacing="10" styleClass="feed-card">
                    <padding>
                        <Insets bottom="12" left="16" right="16" top="12"/>
                    </padding>

                    <HBox alignment="TOP_LEFT" spacing="10">
                        <ProfileAvatar fx:id="composerAvatar" size="40.0" text="Me"/>
                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                            <TextArea fx:id="postTextArea" prefRowCount="4" promptText="Share notes, upload a JPG/GIF/PDF/TXT, or post an update..."
                                      styleClass="input-field" wrapText="true"/>
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label fx:id="selectedFileLabel" styleClass="muted-text" text="No file selected"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="composerStatusLabel" styleClass="muted-text"/>
                            </HBox>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <HBox alignment="CENTER" spacing="8">
                        <Button maxWidth="Infinity" onAction="#onUploadFileClick" prefHeight="36" styleClass="feed-action-button"
                                text="Choose JPG/GIF/PDF/TXT" fx:id="uploadFileButton" HBox.hgrow="ALWAYS"/>
                        <Button maxWidth="Infinity" onAction="#onCreatePostClick" prefHeight="36" styleClass="primary-button"
                                text="Post" fx:id="postButton" HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox fx:id="feedContainer" spacing="22">
                        <padding>
                            <Insets bottom="18" top="4"/>
                        </padding>
                    </VBox>
                </ScrollPane>
            </VBox>

            <VBox prefWidth="260" spacing="6">
                <padding>
                    <Insets bottom="12" left="8" right="12" top="12"/>
                </padding>

                <HBox alignment="CENTER_LEFT">
                    <Label styleClass="section-title" text="Users"/>
                    <Region HBox.hgrow="ALWAYS"/>
                </HBox>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox fx:id="contactsContainer" spacing="0">
                        <padding>
                            <Insets top="4"/>
                        </padding>
                    </VBox>
                </ScrollPane>
            </VBox>
        </HBox>
    </center>
</BorderPane>
