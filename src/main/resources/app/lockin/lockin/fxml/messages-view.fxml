<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="Infinity" maxWidth="Infinity" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="app.lockin.lockin.client.controllers.MessagesController">
    <VBox maxWidth="Infinity" styleClass="surface-panel" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <ScrollPane fx:id="messagesScrollPane" fitToWidth="true" styleClass="message-thread" VBox.vgrow="ALWAYS">
            <VBox fx:id="messagesContainer" spacing="10">
                <padding>
                    <Insets bottom="16" left="16" right="16" top="16"/>
                </padding>
            </VBox>
        </ScrollPane>

        <HBox alignment="CENTER" spacing="8" styleClass="message-input-bar">
            <padding>
                <Insets bottom="10" left="16" right="16" top="10"/>
            </padding>

            <Button fx:id="attachFileBtn" onAction="#onAttachFile" prefHeight="36" prefWidth="36"
                    styleClass="action-icon-button" text="+"/>
            <TextField fx:id="messageInputField" onAction="#onSendMessage" prefHeight="40"
                       promptText="Write a message..." styleClass="input-field" HBox.hgrow="ALWAYS"/>
            <Button fx:id="sendButton" onAction="#onSendMessage" prefHeight="36" prefWidth="72"
                    styleClass="primary-button" text="Send"/>
        </HBox>
    </VBox>
</AnchorPane>
