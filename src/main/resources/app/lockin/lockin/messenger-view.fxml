<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="720" prefWidth="1100" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.lockin.lockin.client.controller.MessengerController">

    <!-- ===================== MAIN BODY ===================== -->
    <center>
        <HBox prefHeight="720" spacing="0">

            <!-- ===== LEFT PANEL: CONVERSATIONS LIST ===== -->
            <VBox prefWidth="360" style="-fx-background-color: white;">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="12" style="-fx-background-color: white; -fx-border-color: transparent transparent #e4e6eb transparent; -fx-border-width: 0 0 1 0;">
                    <padding><Insets left="16" right="16" /></padding>
                    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #050505;" text="Chats" />
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- Icon buttons -->
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: #e4e6eb; -fx-background-radius: 18; -fx-cursor: hand; -fx-font-size: 15; -fx-border-color: transparent;" text="⋯" />
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: #e4e6eb; -fx-background-radius: 18; -fx-cursor: hand; -fx-font-size: 15; -fx-border-color: transparent;" text="✏️" />
                </HBox>

                <!-- Search Bar -->
                <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-background-color: #f0f2f5; -fx-background-radius: 20; -fx-padding: 0 14 0 14;">
                    <padding><Insets bottom="8" left="12" right="12" top="8" /></padding>
                    <Label style="-fx-font-size: 13; -fx-text-fill: #777;" text="🔍" />
                    <TextField prefHeight="34" promptText="Search Messenger" style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-font-size: 14;" HBox.hgrow="ALWAYS" />
                </HBox>

                <!-- Filter Tabs -->
                <HBox spacing="8" style="-fx-padding: 8 12 4 12;">
                    <Button prefHeight="30" style="-fx-background-color: #e7f3ff; -fx-background-radius: 15; -fx-text-fill: #0866ff; -fx-font-size: 13; -fx-font-weight: bold; -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0 14 0 14;" text="Inbox" />
                    <Button prefHeight="30" style="-fx-background-color: #f0f2f5; -fx-background-radius: 15; -fx-text-fill: #050505; -fx-font-size: 13; -fx-cursor: hand; -fx-border-color: transparent; -fx-padding: 0 14 0 14;" text="Communities" />
                </HBox>

                <!-- Conversation List (Scrollable) -->
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="conversationList" spacing="0">

                        <!-- ── Conversation Row 1 (ACTIVE / SELECTED) ── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12" style="-fx-background-color: #e7f3ff; -fx-background-radius: 10; -fx-cursor: hand; -fx-padding: 0 12 0 12;">
                            <padding><Insets left="4" right="4" /></padding>
                            <!-- Avatar with online dot -->
                            <StackPane prefHeight="54" prefWidth="54">
                                <StackPane prefHeight="54" prefWidth="54" style="-fx-background-color: #00C9A7; -fx-background-radius: 27;">
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;" text="A" />
                                </StackPane>
                                <StackPane prefHeight="14" prefWidth="14" style="-fx-background-color: #44c767; -fx-background-radius: 7; -fx-border-color: white; -fx-border-radius: 7; -fx-border-width: 2;" StackPane.alignment="BOTTOM_RIGHT" />
                            </StackPane>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="Abid" />
                                <Label maxWidth="190" style="-fx-font-size: 13; -fx-text-fill: #0866ff;" text="Mama Ghumacchilam" wrapText="false" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <Label style="-fx-font-size: 11; -fx-text-fill: #0866ff;" text="2m" />
                                <StackPane prefHeight="20" prefWidth="20" style="-fx-background-color: #0866ff; -fx-background-radius: 10;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;" text="3" />
                                </StackPane>
                            </VBox>
                        </HBox>

                        <!-- ── Conversation Row 2 ── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 12 0 12;">
                            <padding><Insets left="4" right="4" /></padding>
                            <StackPane prefHeight="54" prefWidth="54">
                                <StackPane prefHeight="54" prefWidth="54" style="-fx-background-color: #f7b731; -fx-background-radius: 27;">
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;" text="S" />
                                </StackPane>
                                <StackPane prefHeight="14" prefWidth="14" style="-fx-background-color: #44c767; -fx-background-radius: 7; -fx-border-color: white; -fx-border-radius: 7; -fx-border-width: 2;" StackPane.alignment="BOTTOM_RIGHT" />
                            </StackPane>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="Atanu" />
                                <Label maxWidth="190" style="-fx-font-size: 13; -fx-text-fill: #65676b;" text="You: Gay" wrapText="false" />
                            </VBox>
                            <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="15m" />
                        </HBox>

                        <!-- ── Conversation Row 3 ── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 12 0 12;">
                            <padding><Insets left="4" right="4" /></padding>
                            <StackPane prefHeight="54" prefWidth="54" style="-fx-background-color: #e74c3c; -fx-background-radius: 27;">
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;" text="T" />
                            </StackPane>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="Tahsinul" />
                                <Label maxWidth="190" style="-fx-font-size: 13; -fx-text-fill: #65676b;" text="You: kys nigga" wrapText="false" />
                            </VBox>
                            <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="1h" />
                        </HBox>

                        <!-- ── Conversation Row 4 ── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 12 0 12;">
                            <padding><Insets left="4" right="4" /></padding>
                            <StackPane prefHeight="54" prefWidth="54">
                                <StackPane prefHeight="54" prefWidth="54" style="-fx-background-color: #8e44ad; -fx-background-radius: 27;">
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 20;" text="F" />
                                </StackPane>
                                <StackPane prefHeight="14" prefWidth="14" style="-fx-background-color: #44c767; -fx-background-radius: 7; -fx-border-color: white; -fx-border-radius: 7; -fx-border-width: 2;" StackPane.alignment="BOTTOM_RIGHT" />
                            </StackPane>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="Farreed" />
                                <Label maxWidth="190" style="-fx-font-size: 13; -fx-text-fill: #65676b;" text="Baggy Jeans" wrapText="false" />
                            </VBox>
                            <VBox alignment="CENTER" spacing="6">
                                <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="3h" />
                                <StackPane prefHeight="20" prefWidth="20" style="-fx-background-color: #0866ff; -fx-background-radius: 10;">
                                    <Label style="-fx-text-fill: white; -fx-font-size: 11; -fx-font-weight: bold;" text="1" />
                                </StackPane>
                            </VBox>
                        </HBox>

                        <!-- ── Conversation Row 5 ── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 12 0 12;">
                            <padding><Insets left="4" right="4" /></padding>
                            <StackPane prefHeight="54" prefWidth="54">
                                <StackPane prefHeight="54" prefWidth="54" style="-fx-background-color: #2980b9; -fx-background-radius: 27;">
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 17;" text="As" />
                                </StackPane>
                                <StackPane prefHeight="14" prefWidth="14" style="-fx-background-color: #44c767; -fx-background-radius: 7; -fx-border-color: white; -fx-border-radius: 7; -fx-border-width: 2;" StackPane.alignment="BOTTOM_RIGHT" />
                            </StackPane>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="Ikra" />
                                <Label maxWidth="190" style="-fx-font-size: 13; -fx-text-fill: #65676b;" text="Goon" wrapText="false" />
                            </VBox>
                            <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="Yesterday" />
                        </HBox>

                        <!-- ── Group Chat Row ── -->
                        <HBox alignment="CENTER_LEFT" prefHeight="72" spacing="12" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-padding: 0 12 0 12;">
                            <padding><Insets left="4" right="4" /></padding>
                            <!-- Group avatar (stacked) -->
                            <StackPane prefHeight="54" prefWidth="54">
                                <StackPane prefHeight="38" prefWidth="38" style="-fx-background-color: #00C9A7; -fx-background-radius: 19;" StackPane.alignment="TOP_LEFT">
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="A" />
                                </StackPane>
                                <StackPane prefHeight="38" prefWidth="38" style="-fx-background-color: #f7b731; -fx-background-radius: 19; -fx-border-color: white; -fx-border-radius: 19; -fx-border-width: 2;" StackPane.alignment="BOTTOM_RIGHT">
                                    <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14;" text="S" />
                                </StackPane>
                            </StackPane>
                            <VBox spacing="3" HBox.hgrow="ALWAYS">
                                <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="LockIn Team 🔒" />
                                <Label maxWidth="190" style="-fx-font-size: 13; -fx-text-fill: #65676b;" text="Kazi: Scat khabo mama" wrapText="false" />
                            </VBox>
                            <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="Mon" />
                        </HBox>

                    </VBox>
                </ScrollPane>

                <!-- Bottom Nav -->
                <HBox alignment="CENTER" spacing="0" style="-fx-background-color: white; -fx-border-color: #e4e6eb transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                    <padding><Insets bottom="8" top="8" /></padding>
                    <Button prefHeight="44" prefWidth="72" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 20; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="💬" />
                    <Button prefHeight="44" prefWidth="72" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 20; -fx-border-color: transparent; -fx-text-fill: #65676b;" text="👥" />
                    <Button prefHeight="44" prefWidth="72" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 20; -fx-border-color: transparent; -fx-text-fill: #65676b;" text="📺" />
                    <Button prefHeight="44" prefWidth="72" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 20; -fx-border-color: transparent; -fx-text-fill: #65676b;" text="⚙️" />
                    <!-- Profile avatar at bottom -->
                    <StackPane prefHeight="36" prefWidth="36" style="-fx-cursor: hand;">
                        <StackPane prefHeight="36" prefWidth="36" style="-fx-background-color: #1B9AAA; -fx-background-radius: 18;">
                            <Label fx:id="bottomNavInitials" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13;" text="U" />
                        </StackPane>
                    </StackPane>
                </HBox>

            </VBox>

            <!-- ===== VERTICAL DIVIDER ===== -->
            <Separator orientation="VERTICAL" />

            <!-- ===== RIGHT PANEL: ACTIVE CHAT ===== -->
            <VBox style="-fx-background-color: white;" HBox.hgrow="ALWAYS">

                <!-- Chat Header -->
                <HBox alignment="CENTER_LEFT" prefHeight="60" spacing="12" style="-fx-background-color: white; -fx-border-color: transparent transparent #e4e6eb transparent; -fx-border-width: 0 0 1 0;">
                    <padding><Insets left="16" right="16" /></padding>
                    <StackPane prefHeight="42" prefWidth="42">
                        <StackPane prefHeight="42" prefWidth="42" style="-fx-background-color: #00C9A7; -fx-background-radius: 21;">
                            <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16;" text="A" />
                        </StackPane>
                        <StackPane prefHeight="13" prefWidth="13" style="-fx-background-color: #44c767; -fx-background-radius: 7; -fx-border-color: white; -fx-border-radius: 7; -fx-border-width: 2;" StackPane.alignment="BOTTOM_RIGHT" />
                    </StackPane>
                    <VBox spacing="2">
                        <Label style="-fx-font-weight: bold; -fx-font-size: 15; -fx-text-fill: #050505;" text="Abid" />
                        <Label style="-fx-font-size: 12; -fx-text-fill: #44c767;" text="Active now" />
                    </VBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <!-- Action Icons -->
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: #e7f3ff; -fx-background-radius: 18; -fx-cursor: hand; -fx-font-size: 16; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="📞" />
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: #e7f3ff; -fx-background-radius: 18; -fx-cursor: hand; -fx-font-size: 16; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="📹" />
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: #e7f3ff; -fx-background-radius: 18; -fx-cursor: hand; -fx-font-size: 16; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="ℹ️" />
                </HBox>

                <!-- Messages Area -->
                <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: white; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <VBox fx:id="messagesContainer" spacing="6">
                        <padding><Insets bottom="16" left="16" right="16" top="16" /></padding>

                        <!-- Date label -->
                        <HBox alignment="CENTER">
                            <Label style="-fx-font-size: 11; -fx-text-fill: #65676b; -fx-font-weight: bold;" text="TODAY" />
                        </HBox>

                        <!-- ── Received Message 1 ── -->
                        <HBox alignment="BOTTOM_LEFT" spacing="8">
                            <StackPane prefHeight="28" prefWidth="28" style="-fx-background-color: #00C9A7; -fx-background-radius: 14;">
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="A" />
                            </StackPane>
                            <VBox maxWidth="340" spacing="4">
                                <Label style="-fx-background-color: #f0f2f5; -fx-background-radius: 18 18 18 4; -fx-padding: 10 14 10 14; -fx-font-size: 14; -fx-text-fill: #050505;" text="hey! did you get a chance to look at the project_report.pdf I sent?" wrapText="true" />
                                <Label style="-fx-font-size: 11; -fx-text-fill: #65676b; -fx-padding: 0 0 0 4;" text="10:42 AM" />
                            </VBox>
                        </HBox>

                        <!-- ── Received: File message ── -->
                        <HBox alignment="BOTTOM_LEFT" spacing="8">
                            <StackPane prefHeight="28" prefWidth="28" style="-fx-background-color: #00C9A7; -fx-background-radius: 14;">
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="A" />
                            </StackPane>
                            <VBox maxWidth="300" spacing="4">
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #f0f2f5; -fx-background-radius: 18 18 18 4; -fx-padding: 12 14 12 14;">
                                    <Label style="-fx-font-size: 26;" text="📄" />
                                    <VBox spacing="3">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #050505;" text="project_report.pdf" />
                                        <Label style="-fx-font-size: 12; -fx-text-fill: #65676b;" text="2.4 MB  ·  PDF" />
                                    </VBox>
                                </HBox>
                                <Label style="-fx-font-size: 11; -fx-text-fill: #65676b; -fx-padding: 0 0 0 4;" text="10:43 AM" />
                            </VBox>
                        </HBox>

                        <!-- ── Sent Message ── -->
                        <HBox alignment="BOTTOM_RIGHT" spacing="8">
                            <VBox alignment="CENTER_RIGHT" maxWidth="340" spacing="4">
                                <Label style="-fx-background-color: #0866ff; -fx-background-radius: 18 18 4 18; -fx-padding: 10 14 10 14; -fx-font-size: 14; -fx-text-fill: white;" text="yeah I just opened it! looks great 🔥 will review and get back to you" wrapText="true" />
                                <HBox alignment="CENTER_RIGHT" spacing="4">
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="10:45 AM" />
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #0866ff;" text="✓✓" />
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- ── Received Message 2 ── -->
                        <HBox alignment="BOTTOM_LEFT" spacing="8">
                            <StackPane prefHeight="28" prefWidth="28" style="-fx-background-color: #00C9A7; -fx-background-radius: 14;">
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="A" />
                            </StackPane>
                            <VBox maxWidth="340" spacing="4">
                                <Label style="-fx-background-color: #f0f2f5; -fx-background-radius: 18 18 18 4; -fx-padding: 10 14 10 14; -fx-font-size: 14; -fx-text-fill: #050505;" text="awesome! also sent the updated dataset file 👇" wrapText="true" />
                                <Label style="-fx-font-size: 11; -fx-text-fill: #65676b; -fx-padding: 0 0 0 4;" text="10:47 AM" />
                            </VBox>
                        </HBox>

                        <!-- ── Received: Another file ── -->
                        <HBox alignment="BOTTOM_LEFT" spacing="8">
                            <StackPane prefHeight="28" prefWidth="28" style="-fx-background-color: #00C9A7; -fx-background-radius: 14;">
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="A" />
                            </StackPane>
                            <VBox maxWidth="300" spacing="4">
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #f0f2f5; -fx-background-radius: 18 18 18 4; -fx-padding: 12 14 12 14;">
                                    <Label style="-fx-font-size: 26;" text="📊" />
                                    <VBox spacing="3">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: #050505;" text="dataset_v2.xlsx" />
                                        <Label style="-fx-font-size: 12; -fx-text-fill: #65676b;" text="1.1 MB  ·  Excel Sheet" />
                                    </VBox>
                                    <Button prefHeight="30" prefWidth="30" style="-fx-background-color: #0866ff; -fx-background-radius: 15; -fx-cursor: hand; -fx-font-size: 13; -fx-border-color: transparent; -fx-text-fill: white;" text="↓" />
                                </HBox>
                                <Label style="-fx-font-size: 11; -fx-text-fill: #65676b; -fx-padding: 0 0 0 4;" text="10:47 AM" />
                            </VBox>
                        </HBox>

                        <!-- ── Sent File ── -->
                        <HBox alignment="BOTTOM_RIGHT" spacing="8">
                            <VBox alignment="CENTER_RIGHT" maxWidth="300" spacing="4">
                                <HBox alignment="CENTER_LEFT" spacing="12" style="-fx-background-color: #0866ff; -fx-background-radius: 18 18 4 18; -fx-padding: 12 14 12 14;">
                                    <Label style="-fx-font-size: 26;" text="📎" />
                                    <VBox spacing="3">
                                        <Label style="-fx-font-weight: bold; -fx-font-size: 13; -fx-text-fill: white;" text="lockin_mockup.fxml" />
                                        <Label style="-fx-font-size: 12; -fx-text-fill: #c8dcff;" text="48 KB  ·  FXML File" />
                                    </VBox>
                                </HBox>
                                <HBox alignment="CENTER_RIGHT" spacing="4">
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #65676b;" text="10:50 AM" />
                                    <Label style="-fx-font-size: 11; -fx-text-fill: #0866ff;" text="✓✓" />
                                </HBox>
                            </VBox>
                        </HBox>

                        <!-- ── Typing indicator ── -->
                        <HBox alignment="BOTTOM_LEFT" spacing="8">
                            <StackPane prefHeight="28" prefWidth="28" style="-fx-background-color: #00C9A7; -fx-background-radius: 14;">
                                <Label style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11;" text="A" />
                            </StackPane>
                            <HBox alignment="CENTER" spacing="4" style="-fx-background-color: #f0f2f5; -fx-background-radius: 18; -fx-padding: 12 18 12 18;">
                                <Label style="-fx-font-size: 10; -fx-text-fill: #65676b;" text="● ● ●" />
                            </HBox>
