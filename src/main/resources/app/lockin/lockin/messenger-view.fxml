                    </VBox>
                </ScrollPane>

                <!-- ── Input Bar ── -->
                <HBox alignment="CENTER" spacing="8" style="-fx-background-color: white; -fx-border-color: #e4e6eb transparent transparent transparent; -fx-border-width: 1 0 0 0;">
                    <padding><Insets bottom="10" left="16" right="16" top="10" /></padding>

                    <!-- Attachment / emoji buttons -->
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="➕" />
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="🖼️" />
                    <Button fx:id="attachFileBtn" onAction="#onAttachFile" prefHeight="36" prefWidth="36" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="📎" />
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 18; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="🎤" />

                    <!-- Text input -->
                    <TextField fx:id="messageInputField" prefHeight="40" promptText="Aa" style="-fx-background-color: #f0f2f5; -fx-background-radius: 20; -fx-padding: 0 16 0 16; -fx-font-size: 14; -fx-border-color: transparent;" HBox.hgrow="ALWAYS" />

                    <!-- Emoji -->
                    <Button prefHeight="36" prefWidth="36" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 20; -fx-border-color: transparent;" text="😊" />

                    <!-- Send / Like button -->
                    <Button fx:id="sendButton" onAction="#onSendMessage" prefHeight="36" prefWidth="36" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 22; -fx-border-color: transparent; -fx-text-fill: #0866ff;" text="👍" />
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
